# Keep the Docker build context small. The deploy image (Dockerfile.deploy)
# builds the frontend and backend from source inside the image, so none of
# these local build artifacts are needed in the context.
.git/
target/
**/target/
node_modules/
**/node_modules/
frontend/dist/
**/dist/
**/pkg/
.github/
*.md
.env
.env.*
!.env.example

# Training pipeline + generated data (not needed in the runtime image)
training/
