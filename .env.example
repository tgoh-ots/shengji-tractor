# ─────────────────────────────────────────────────────────────────────────────
# Example environment configuration for the Shengji backend.
# Copy to `.env` (gitignored) and fill in real values. NEVER commit `.env`.
# All values below are non-secret defaults safe to share.
# ─────────────────────────────────────────────────────────────────────────────

# Comma-separated allowlist of origins permitted to call the backend (CORS + WS).
# In production set this to your deployed frontend origin(s), e.g.
#   CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
# Do NOT use "*" in production. If unset, defaults to localhost dev origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3030,http://127.0.0.1:3000,http://127.0.0.1:3030

# Public wss:// URL the frontend should connect to for the game socket.
# Leave unset for local dev (frontend infers same-origin). In production this
# points the Vercel-hosted frontend at the Koyeb-hosted backend, e.g.
#   WEBSOCKET_HOST=wss://your-backend.koyeb.app/api
# WEBSOCKET_HOST=

# Build/version label surfaced in logs and the UI footer.
VERSION=dev

# On-disk paths for the periodic in-memory state snapshot (crash/restart recovery).
DUMP_PATH=/tmp/shengji_state.json
MESSAGE_PATH=/tmp/shengji_messages.json

# ── Secrets (leave blank in this example; set real values only in `.env` / the
# ── host's secret store, e.g. Koyeb/Vercel env settings — never in git) ───────

# Optional Sentry error-reporting DSN (server-side only). Blank disables Sentry.
# SENTRY_DSN=

# Optional Upstash Redis (active-game snapshot durability across host sleeps).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
